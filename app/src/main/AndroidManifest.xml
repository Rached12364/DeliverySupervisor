<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions pour accéder à la galerie -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:requestLegacyExternalStorage="true"
        android:theme="@style/Theme.APPLICATIONMOBILESUPERVISIONDESLIVRAISONS">

        <!-- SPLASH ACTIVITY (écran de chargement style Netflix) -->
        <activity
            android:name=".SplashActivityNetflix"
            android:exported="true"
            android:theme="@style/Theme.SplashNetflix">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- LOGIN UNIQUE (remplace les deux anciennes activités de login) -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Dashboard contrôleur (héberge tous les fragments) -->
        <activity
            android:name=".ControllerDashboardActivity"
            android:exported="false" />

        <!-- Dashboard livreur -->
        <activity
            android:name=".DeliverymanDashboardActivity"
            android:label="@string/title_activity_deliveryman_dashboard"
            android:exported="false" />

        <!-- Profil Contrôleur -->
        <activity
            android:name=".ProfileControllerActivity"
            android:exported="false"
            android:parentActivityName=".ControllerDashboardActivity"
            android:theme="@style/Theme.APPLICATIONMOBILESUPERVISIONDESLIVRAISONS" />

        <!-- Profil Livreur (si tu en as un) -->
        <!--
        <activity
            android:name=".ProfileLivreurActivity"
            android:exported="false"
            android:parentActivityName=".DeliverymanDashboardActivity" />
        -->

    </application>

</manifest>