<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige_button"
    android:gravity="center">

    <!-- Animation container -->
    <LinearLayout
        android:id="@+id/animation_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logo_image"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter" />

        <!-- Nom de l'application -->
        <TextView
            android:id="@+id/app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:alpha="0" />

        <!-- Camion animé vers la GAUCHE -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="48dp">

            <!-- Camion emoji qui avance vers la GAUCHE 💨🚚 -->
            <TextView
                android:id="@+id/truck_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚚"
                android:textSize="56sp"
                android:textColor="@color/white"
                android:alpha="0.9" />

            <!-- Route (ligne de progression) -->
            <View
                android:id="@+id/road_line"
                android:layout_width="220dp"
                android:layout_height="3dp"
                android:layout_marginTop="12dp"
                android:background="#80FFFFFF" />

            <!-- Barre de progression qui avance de DROITE vers GAUCHE -->
            <View
                android:id="@+id/progress_line"
                android:layout_width="0dp"
                android:layout_height="3dp"
                android:layout_marginTop="-3dp"
                android:background="@color/white"
                android:layout_gravity="start" />

            <!-- Pourcentage -->
            <TextView
                android:id="@+id/tv_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="0%"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>