<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_message_urgence.xml -->
<!-- Carte pour l'historique des messages d'urgence du livreur -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="#FFF3E0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_message_urgence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tv_horodatage_urgence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/beige_text_secondary"
            android:textSize="10sp"
            android:gravity="end"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>