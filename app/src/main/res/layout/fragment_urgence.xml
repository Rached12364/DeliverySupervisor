<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- SECTION 1 : MESSAGES RECUS DU CONTROLEUR -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#E8F5E9">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_message"
                        android:tint="#1B5E20"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Messages du contr&#244;leur"
                        android:textColor="#1B5E20"
                        android:textSize="17sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Appuyez sur un message pour le marquer comme lu"
                    android:textColor="#388E3C"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:id="@+id/container_messages_recus_livreur"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SECTION 2 : ENVOYER UNE URGENCE -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFEBEE">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_urgence"
                        android:tint="#D32F2F"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Message d'Urgence"
                        android:textColor="#D32F2F"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Envoyer une alerte imm&#233;diate au contr&#244;leur"
                    android:textColor="#E57373"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Selection commande -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Commande concern&#233;e *"
                    android:textColor="@color/beige_text_primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <!-- Spinner fond blanc visible -->
                <Spinner
                    android:id="@+id/spinner_commande_urgence"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/spinner_bg_custom"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:popupBackground="@color/white"
                    android:dropDownWidth="match_parent"
                    android:layout_marginBottom="12dp"
                    android:theme="@style/ThemeOverlay.AppCompat.Light"/>

                <!-- Infos commande / client -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/white"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_delivery"
                        android:tint="@color/beige_text_secondary"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/tv_nocde_info"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/beige_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_phone"
                        android:tint="#4CAF50"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:id="@+id/tv_tel_client_urgence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#4CAF50"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Raisons predefinies -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Raison (une ou plusieurs) *"
                    android:textColor="@color/beige_text_primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_raison"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:chipSpacingVertical="8dp"
                    app:chipSpacingHorizontal="8dp"
                    app:singleLine="false"/>

                <!-- Message complementaire -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Message compl&#233;mentaire (optionnel)"
                    android:textColor="@color/beige_text_primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/edit_message_libre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="100dp"
                    android:gravity="top|start"
                    android:hint="&#201;crivez votre message..."
                    android:textColor="#1C1008"
                    android:textColorHint="#9A8070"
                    android:textSize="14sp"
                    android:background="@drawable/spinner_bg_custom"
                    android:padding="12dp"
                    android:inputType="textMultiLine"
                    android:lines="3"
                    android:maxLines="5"
                    android:layout_marginBottom="16dp"/>

                <!-- Bouton envoyer avec icone send -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_envoyer_urgence"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="ENVOYER L'URGENCE"
                    app:backgroundTint="#D32F2F"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_send"
                    app:iconGravity="textStart"
                    app:iconTint="@color/white"
                    app:iconSize="20dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SECTION 3 : HISTORIQUE -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_history"
                        android:tint="@color/beige_button"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Historique des urgences"
                        android:textColor="@color/beige_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/container_historique_urgence"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>