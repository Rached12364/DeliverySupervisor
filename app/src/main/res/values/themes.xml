<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.APPLICATIONMOBILESUPERVISIONDESLIVRAISONS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#B8935A</item>
        <item name="colorPrimaryVariant">#8B6A35</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#B8935A</item>
        <item name="colorSecondaryVariant">#8B6A35</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">#B8935A</item>
        <item name="android:windowBackground">#FAF6F1</item>
        <item name="android:textColor">#1C1008</item>
        <item name="android:textColorHint">#6B5040</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Theme.APPLICATIONMOBILESUPERVISIONDESLIVRAISONS" parent="Base.Theme.APPLICATIONMOBILESUPERVISIONDESLIVRAISONS" />

    <style name="Theme.SplashNetflix" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#B8935A</item>
        <item name="android:statusBarColor">#B8935A</item>
        <item name="android:navigationBarColor">#B8935A</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="CustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">#B8935A</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="hintTextColor">#3D2B10</item>
        <item name="android:textColorHint">#6B5040</item>
        <item name="boxBackgroundColor">#FFFFFF</item>
        <item name="boxBackgroundMode">outline</item>
    </style>

    <style name="CustomTextInputEditText">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#1C1008</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:background">@drawable/edittext_background</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="CustomSpinner">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:background">@drawable/spinner_bg_custom</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#1C1008</item>
        <item name="android:padding">12dp</item>
        <item name="android:dropDownWidth">match_parent</item>
        <item name="android:popupBackground">@color/white</item>
    </style>

    <style name="CustomButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:padding">12dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="backgroundTint">#B8935A</item>
    </style>

    <style name="CustomCardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="TitleText">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#B8935A</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="SubtitleText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#3D2B10</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="FormLabel">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#1C1008</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>

    <style name="CircleImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>